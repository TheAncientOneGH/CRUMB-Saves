        <anyType xsi:type="xsd:string">// [[[[ --- Begin Editable Options --- ]]]]
//
// Turns button check delay on or off
// Default: true
const bool btnDelayEnable = true;
//
// Change the delay values at your own risk
// of breaking it. Added for convienience..
// Values are ms of course
//
// How often checks are made for button presses
// Goes without the need to say, this value is
// ignored if above is set false
// Default: 100
const int btnDelay = 100;
// How often to refresh displays
// Default: 100
const int refreshDelay = 100;
// Boots Arduino with a quick power on self-test
// It's a glorified quick, fake, but cool sequence.
// Default: true
bool post = true;
// Toggle true and program will also reset mode
// to default when the reset button is pressed.
// (Not sure why anyone would want to set mode
// each display clear but to each their own...)
// Default: false
bool resetMode = false;
// Just a loop that will run opposing and shared
// segments. Sends Serial Out of the segment number.
// Default: false
bool runTestLoop = false;
//
// [[[[ --- End Editable Options --- ]]]]

// Some comments (notes) are meant as reference and/or
// for the would be new player who wants to learn
// how code functions. To make it easier and in an
// attempt to help, I have outlined a few things within
// this program. Code is by far not optimized to be the
// best way to do something, it is setup in a way that
// makes learning and understanding the code easier.

// Registers
// Similar names means even I don't need to
// reference them (cause, not getting younger)
const int SER = 7;			// Data (Displays) 1st Register (Segment Displays)
const int SERL = 8;			// Latch
const int SERC = 9;			// Clock
const int SER2 = 10;		// Data 2 (Mode) - 2nd Register (LED's)
const int SER2L = 11;		// Latch 2
const int SER2C= 12;		// Clock 2

// Buttons
// I could just do a, b, c, d ... I like staying
// in habit of making them descriptive without
// writing an essay. In my case here 'a' is the
// register pin (Qa) while 'x' denotes 'Push' or
// 'Button'. 's' denotes Switch
const int ax = 2;
const int bx = 3;
const int cx = 4;
const int dx = 5;
const int ex = 6;
const int fx = A0;
const int gx = A1;
const int px = A2;
const int rx = A3;
const int mx = A4;
// Test Mode Switch
const int ts = A5;
// Serial Out Switch
const int ss = 13;
// I would likely leave the below vars alone.
// They get set as needed by the program loop
unsigned long TS = millis();
unsigned int btnTimer = 0;
unsigned long refreshTimer = 0;
// Sure, I could just write 0 but Why go with
// the flow when against the grain is more fun.
byte defBin = B00000000;
// Why not 0 or thisvar = defBin
// because we can, No real reason
byte defBitFlip = B00000000;
byte lastBin = B00000000;
// Measured 1/8th Byte (joking)
byte defPost = B00000001;
// Set Defaults
int mode = 0;
int lastmode = 0;
bool testMode = false;
bool serOut = false;
// Trigger for skipping normal routine to
// process button input
bool skip = false;
// Mark if it was a binary input button pressed
bool binbtn = false;
// Pressed button stored here, using an invalid
// number just to verify an actual press on 0
int btn = 50;
// Flagged as false if button is being pressed
bool btnReleased = true;
//
const int otherbtns[2] = {A3, A4};
// No multi-dimensional array's in CRUMB? :'(
//
// List of button orders for each mode. (except Mode 4
// which is a test mode that has its own independant
// routine)
//
// Physical Button Order (Pins D2-D5, A0-A2) - 8 Pins
//			 0   1   2   3   4   5   6   7
int bitMapping[8] = {ax, bx, cx, dx, ex, fx, gx, px};
//
// Anyone else play Bitburner? Free game on
// Steam, great coding/scripting game allowing you to do
// a lot of custom coding in JS, check it out. Also has
// Github version you can grab and play without Steam
// Supports deep nested multi-dimensional arrays for any
// data junkies out there..
//
// Mode Remaps
//
int bitOrder[8];
int bitOrder0[8] = {7, 6, 5, 4, 3, 2, 1, 0};
int bitOrder1[8] = {0, 1, 2, 3, 4, 5, 6, 7};
int bitOrder2[8] = {4, 3, 2, 7, 1, 0, 5, 6};

// Modes in binary, sent to second register (SER2) so we
// can update the LED that is illuminated, written as full
// binary because Y !
const byte modes[4] = {
	B00000001, B00000010, B00000100, B00001000
};

// -[ 7-segment Display (0-9) (Standard Common Cathode) ]-
// B00000000 would be all off
const byte digs[10] = {
	B00111111, B00000110, B01011011, B01001111,
	B01100110, B01101101, B01111101, B00000111,
	B01111111, B01101111
};

// -[ 7-segment Display (Segments 1-8) (Standard Common Cathode) ]-
const byte segs[8] = {
	B00000001, B00000010, B00000100, B00001000,
	B00010000, B00100000, B01000000, B10000000
};

void setup() {
	Serial.begin(115200);
	pinMode(SER, OUTPUT);
	pinMode(SER2, OUTPUT);
	pinMode(SERL, OUTPUT);
	pinMode(SERC, OUTPUT);
	pinMode(SER2L, OUTPUT);
	pinMode(SER2C, OUTPUT);
	pinMode(ax, INPUT_PULLUP);
	pinMode(bx, INPUT_PULLUP);
	pinMode(cx, INPUT_PULLUP);
	pinMode(dx, INPUT_PULLUP);
	pinMode(ex, INPUT_PULLUP);
	pinMode(fx, INPUT_PULLUP);
	pinMode(gx, INPUT_PULLUP);
	pinMode(px, INPUT_PULLUP);
	pinMode(ss, INPUT_PULLUP);
	digitalWrite(ax, HIGH);
	digitalWrite(bx, HIGH);
	digitalWrite(cx, HIGH);
	digitalWrite(dx, HIGH);
	digitalWrite(ex, HIGH);
	digitalWrite(fx, HIGH);
	digitalWrite(gx, HIGH);
	digitalWrite(px, HIGH);
	digitalWrite(ss, HIGH);
	changeMode();
	if (post) {
		pwrOnSelfTest();
	}
	if (runTestLoop) {
		testLoop();
	}
}

// I still want a hula-hoop ~ Alvin
void loop() {
	// We use millis function to track passed time
	TS = millis();
	// Check if test mode switch is enabled
	int tmswitch = analogRead(ts);

	// Mark test mode as enabled or not
	// if it is, store some data such as mode
	// so we can revert things back to before testing
	if (tmswitch &gt; 0 &amp;&amp; !testMode) {
		lastmode = mode;
		testMode = true;
		digitalWrite(SER2L, LOW);
		shiftOut(SER2, SER2C, MSBFIRST, modes[3]);
		digitalWrite(SER2L, HIGH);
	} else if (tmswitch == 0 &amp;&amp; testMode) {
		testMode = false;
		mode = lastmode;
		lastmode = 0;
		digitalWrite(SER2L, LOW);
		shiftOut(SER2, SER2C, MSBFIRST, modes[mode]);
		digitalWrite(SER2L, HIGH);
		digitalWrite(SERL, LOW);
		shiftOut(SER, SERC, MSBFIRST, lastBin);
		digitalWrite(SERL, HIGH);
		lastBin = B00000000;
	}

	// See if Serial Out switch is enabled
	if (digitalRead(ss) == LOW &amp;&amp; !serOut) {
		serOut = true;
		Serial.println("Serial Output Enabled");
	} else if (digitalRead(ss) == HIGH &amp;&amp; serOut) {
		Serial.println("Serial Output Disabled");
		serOut = false;
	}

	// If test mode is enabled, run it
	if (testMode) {
		runTests();
	// otherwise, run normal routine
	} else {
		// Use button delay to help prevent over
		// checking button presses (can reduce
		// potential lag &amp; misclick data)
		if (btnDelayEnable) {
			if (TS - btnTimer &gt;= btnDelay) {
				checkButtons();
				btnTimer = TS;
			}
		} else {
			checkButtons();
		}

		// Refresh/Update display data incase something
		// changed without flooding checks
		if (TS - refreshTimer &gt;= refreshDelay) {
			refresh();
			refreshTimer = TS;
		}
	}
}

void checkButtons() {
	// Loop through and find what button is being
	// pressed. Temporarily mark as not pressed, this
	// aids in checking against the global btnPressed
	// var so we can skip further processing the button
	// if the end user is holding the button down
	bool tempPressed = false;
	int tmpBtn = 50;

	for (int i = 0; i &lt; 8; i++) {
		// Check from first to last Binary Button
		// in order, see if any of the buttons are
		// pressed. Remember, our binary input buttons
		// start at pin 2-5 and skip on to A0-A2, so
		// we use the buttonMapping array to define 0-7
		// for the buttons making it less complicated to
		// loop through them all, both Digital and Analog
		if (i &lt; 5) {
			if (digitalRead(bitMapping[i]) == LOW) {
				tempPressed = true;
				tmpBtn = bitOrder[i];
			}
		} else {
			if (analogRead(bitMapping[i]) &gt; 0) {
				tempPressed = true;
				tmpBtn = bitOrder[i];
			}
		}

		if (tempPressed &amp;&amp; btnReleased &amp; tmpBtn != 50) {
			binbtn = true;
			btn = tmpBtn;
			skip = true;
			// Hit the brakes on the for loop if a button
			// was pressed and released. No need to waste
			// cycle time
			break;
		}
	}

	// If no previous buttons are pressed, lets check
	// reset and mode buttons
	if (!skip &amp;&amp; !tempPressed &amp;&amp; btnReleased) {
		for (int i = 0; i &lt; 2; i++) {
			int btnVal = analogRead(otherbtns[i]);
			// Analog
			// Who is Ana Log? Don't remember her
			if (btnVal &gt; 0) {
				btn = i;
				skip = true;
				tempPressed = true;
				btnReleased = false;
				// No break here, only 2 items..
			}
		}
	}

	// If nothing above is being pressed, mark buttons as
	// not pressed
	if (!tempPressed) {
		btnReleased = true;
	}

	// Process button press, but prevent button bouncing
	// (rapid button repeating/toggling)
	// Btw, I purposely made it so Mode will actually still
	// repeat, at a slower rate. Can you fix it? If you figure
	// it out, post your snippet(s) of code that fixes the issue.
	// just something I am leaving behind for you to tinker with :)
	// That is, if you want to tinker with it.. If you do and post
	// code, make sure your fix does not break any of the other
	// functions and test modes
	if (skip &amp;&amp; binbtn &amp;&amp; btnReleased &amp;&amp; !tempPressed) {
		buttons();
	} else if (skip &amp;&amp; !binbtn &amp;&amp; btnReleased &amp;&amp; !tempPressed) {
		buttons();
	}
}

void buttons() {
	// If a button was flagged as being pressed, lets begin
	// processing the information
	if (skip &amp;&amp; binbtn &amp;&amp; btnReleased) {
		int reWire = btn;
		defBin ^= (1 &lt;&lt; reWire);
		skip = false;
		binbtn = false;
		btn = 50;

		if (serOut) {
			Serial.println("---------------------------");
			// Binary of the current segment edits you
			// made or are viewing
			Serial.println(defBin, BIN);
			// Binary needed to display the above data on
			// an upside down display
			Serial.println(flipSegments(defBin), BIN);
			Serial.println("---------------------------");
		}
	// Process Reset or Mode button if pressed
	} else if (skip &amp;&amp; !binbtn &amp;&amp; btnReleased) {
		if (btn == 0) {
			skip = false;
			binbtn = false;	
			btn = 50;
			if (resetMode) {
				mode = 0;
				lastmode = 0;
			}
			changeMode();
			resetDisplays();
		} else if (btn == 1) {
			mode++;
			if (mode &gt; 2) {
				mode = 0;
			}
			skip = false;
			binbtn = false;	
			btn = 50;
			changeMode();
		}
	}
}

void resetDisplays() {
	defBin = B00000000;
	defBitFlip = B00000000;
	digitalWrite(SERL, LOW);
	shiftOut(SER, SERC, MSBFIRST, defBin);
	digitalWrite(SERL, HIGH);
}

void refresh() {
	digitalWrite(SERL, LOW);
	shiftOut(SER, SERC, MSBFIRST, defBin);
	digitalWrite(SERL, HIGH);
}

void changeMode() {
	Serial.println("Mode Change: ");
	Serial.println(mode);
	digitalWrite(SER2L, LOW);
	shiftOut(SER2, SER2C, MSBFIRST, modes[mode]);
	digitalWrite(SER2L, HIGH);
	// Change modes copying new button order into the
	// bitOrder array
	if (mode == 0) {
		for (int i = 0; i &lt; 8; i++) {
			bitOrder[i] = bitOrder0[i];
		}
	} else if (mode == 1) {
		for (int i = 0; i &lt; 8; i++) {
			bitOrder[i] = bitOrder1[i];
		}
	} else if (mode == 2) {
		for (int i = 0; i &lt; 8; i++) {
			bitOrder[i] = bitOrder2[i];
		}
	}
	resetDisplays();
}

byte flipSegments(byte segData) {
	byte flipped = 0;
	// Let's remap segment data to convert binary for
	// displaying the data right side up on an upside
	// down segment display
	if (segData &amp; B00000001) flipped |= B00001000; // a -&gt; d
	if (segData &amp; B00000010) flipped |= B00010000; // b -&gt; e  
	if (segData &amp; B00000100) flipped |= B00100000; // c -&gt; f
	if (segData &amp; B00001000) flipped |= B00000001; // d -&gt; a
	if (segData &amp; B00010000) flipped |= B00000010; // e -&gt; b
	if (segData &amp; B00100000) flipped |= B00000100; // f -&gt; c
	if (segData &amp; B01000000) flipped |= B01000000; // g -&gt; g
	if (segData &amp; B10000000) flipped |= B10000000; // dp -&gt; dp
	return flipped;
}

void runTests() {
	bool skip = false;
	if (serOut) {
		Serial.println("-[ Digits ]-");
	}

	for (int i = 0; i &lt; sizeof(digs); i++) {
		if (analogRead(ts) == 0) {
			skip = true;
			if (serOut) {
				Serial.println("Testing Interrupted...\n");
			}
			break;
		}
		if (serOut &amp; !skip) {
			Serial.println(i);
		}
		digitalWrite(SERL, LOW);
		shiftOut(SER, SERC, MSBFIRST, digs[i]);
		digitalWrite(SERL, HIGH);
		delay(1000);
	}

	if (serOut &amp; !skip) {
		Serial.println("-[ Digits Complete ]-");
		Serial.println("\n");
	}

	if (serOut &amp; !skip) {
		Serial.println("-[ Segments ]-");
	}

	for (int i = 0; i &lt; sizeof(segs); i++) {
		if (analogRead(ts) == 0) {
			if (serOut &amp; !skip) {
				Serial.println("Testing Interrupted...\n");
			}
			break;
		}
		if (serOut &amp; !skip) {
			Serial.println(i + 1);
		}
		digitalWrite(SERL, LOW);
		shiftOut(SER, SERC, MSBFIRST, segs[i]);
		digitalWrite(SERL, HIGH);
		delay(1000);
	}

	if (serOut &amp; !skip) {
		Serial.println("-[ Segments Complete ]-");
		Serial.println("\n");
	}
}

void pwrOnSelfTest() {
	// A total waste of time and an uneeded POST
	// But.. just for fun a fake Power On Self Test
	// .. and yes, alternating beteen mode 1 led
	// and other 3
	if (digitalRead(ss) == LOW) {
		Serial.println("-[ Power On Self-Test ]-");
	}
	for (int i = 0; i &lt; sizeof(segs); i++) {
		if (digitalRead(ss) == LOW) {
			Serial.println(i + 1);
		}
		defPost ^= (1 &lt;&lt; 0);
		defPost ^= (1 &lt;&lt; 1);
		defPost ^= (1 &lt;&lt; 2);
		defPost ^= (1 &lt;&lt; 3);
		digitalWrite(SER2L, LOW);
		shiftOut(SER2, SER2C, MSBFIRST, defPost);
		digitalWrite(SER2L, HIGH);
		digitalWrite(SERL, LOW);
		shiftOut(SER, SERC, MSBFIRST, segs[i]);
		digitalWrite(SERL, HIGH);
		delay(500);
	}
	if (digitalRead(ss) == LOW) {
		Serial.println("-[ Power On Self-Test Complete ]-");
	}
	// Pointlessly set this back to default
	// even though it won't run until power cycle
	// or reset cause I am kewl like that.
	defPost = B00000001;
	if (post) {
		post = false;
	}
}

void testLoop() {
	while (true) {
		for (int i = 0; i &lt; 8; i++) {
			Serial.println("0");
			digitalWrite(SERL, LOW);
			shiftOut(SER, SERC, MSBFIRST, segs[i]);
			digitalWrite(SERL, HIGH);
			Serial.println("\t-----");
			delay(2000);
		}
	}
}
