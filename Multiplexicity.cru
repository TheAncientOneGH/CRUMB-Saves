        <anyType xsi:type="xsd:string">/*

4x15 Multiplexing/Cascading LED Array

Instructions by: TheAncientOne

What's Needed:
  - 60x Standard LEDS
  - 2x 74HC595 Shift Registers
  - 4x NPN Transistors
  - Arduino
  - Wires
  - Time

Effects Included:
  - Snake Effect
  - Fireworks Effect
  - Wave Pattern
  - Falling rain
  - Spiral Chase
  - Expanding Pulse
  - Bounce Effect
  - Matrix Effect
  - Ripple Effect

Instructions:

Shift Register Chain (for 15 columns):

Arduino Pin 2 → SR1 DS (data)
Arduino Pin 3 → SR1 SHCP (clock) → SR2 SHCP
Arduino Pin 4 → SR1 STCP (latch) → SR2 STCP
SR1 Q7' → SR2 DS (cascade)

Row Control (4 rows):

Arduino Pin 5 → NPN Transistor Base → Row 0
Arduino Pin 6 → NPN Transistor Base → Row 1  
Arduino Pin 7 → NPN Transistor Base → Row 2
Arduino Pin 8 → NPN Transistor Base → Row 3

LED Matrix:

Columns: SR outputs → 220Ω resistors → LED anodes
Rows: Transistor collectors → LED cathodes
Transistor emitters → GND

Power:

VCC (5V) to shift registers
GND connections to Arduino, shift registers, transistor emitters

*/
const int dataPin = 2;
const int clockPin = 3;
const int latchPin = 4;
const int rowPins[4] = {5, 6, 7, 8};

bool ledGrid[4][15] = {false};
int currentRow = 0;
unsigned long lastUpdate = 0;
unsigned long effectTimer = 0;
int effectMode = 0;
int effectStep = 0;

void setup() {
	pinMode(dataPin, OUTPUT);
	pinMode(clockPin, OUTPUT);
	pinMode(latchPin, OUTPUT);
	for (int i = 0; i &lt; 4; i++) {
		pinMode(rowPins[i], OUTPUT);
		digitalWrite(rowPins[i], HIGH); // Common cathode setup
	}
}

void loop() {
	// Multiplex display (every 2ms)
	if (millis() - lastUpdate &gt;= 2) {
		updateDisplay();
		lastUpdate = millis();
	}
	// Update effects (every 100ms)
	if (millis() - effectTimer &gt;= 100) {
		runEffect();
		effectTimer = millis();
	}
}

void updateDisplay() {
  // Turn off all rows
  for (int i = 0; i &lt; 4; i++) {
    digitalWrite(rowPins[i], HIGH);
  }
  
  // Shift out column data for current row
  digitalWrite(latchPin, LOW);
  shiftOut(dataPin, clockPin, MSBFIRST, getColumnByte(currentRow, 8));
  shiftOut(dataPin, clockPin, MSBFIRST, getColumnByte(currentRow, 0));
  digitalWrite(latchPin, HIGH);
  
  // Enable current row
  digitalWrite(rowPins[currentRow], LOW);
  
  currentRow = (currentRow + 1) % 4;
}

byte getColumnByte(int row, int startCol) {
  byte result = 0;
  for (int i = 0; i &lt; 8 &amp;&amp; (startCol + i) &lt; 15; i++) {
    if (ledGrid[row][startCol + i]) {
      result |= (1 &lt;&lt; (7 - i));
    }
  }
  return result;
}

void runEffect() {
  if (effectMode == 0) waveEffect();
  else if (effectMode == 1) rainEffect();
  else if (effectMode == 2) spiralEffect();
  else if (effectMode == 3) pulseEffect();
  else if (effectMode == 4) snakeEffect();
  else if (effectMode == 5) fireworksEffect();
  else if (effectMode == 6) bounceEffect();
  else if (effectMode == 7) matrixEffect();
  else if (effectMode == 8) rippleEffect();
  
  effectStep++;
  if (effectStep &gt; 50) {
    effectStep = 0;
    effectMode = (effectMode + 1) % 9; // Update for 9 effects
    clearGrid();
  }
}

void snakeEffect() {
  clearGrid();
  int length = 8;
  for (int i = 0; i &lt; length; i++) {
    int pos = (effectStep + i) % 60;
    int row = pos / 15;
    int col = pos % 15;
    ledGrid[row][col] = true;
  }
}

void fireworksEffect() {
  clearGrid();
  int centerRow = 2;
  int centerCol = 7 + sin(effectStep * 0.3) * 5;
  int explosion = effectStep % 15;
  
  for (int row = 0; row &lt; 4; row++) {
    for (int col = 0; col &lt; 15; col++) {
      int dist = sqrt(pow(row - centerRow, 2) + pow(col - centerCol, 2));
      if (dist == explosion || (explosion &gt; 8 &amp;&amp; random(100) &lt; 30)) {
        ledGrid[row][col] = true;
      }
    }
  }
}

void bounceEffect() {
  clearGrid();
  int ballRow = abs((effectStep % 20) - 10) / 3;
  int ballCol = effectStep % 15;
  
  // Ball trail
  for (int i = 0; i &lt; 3; i++) {
    int trailCol = (ballCol - i + 15) % 15;
    if (ballRow + i &lt; 4) ledGrid[ballRow + i][trailCol] = true;
  }
  ledGrid[ballRow][ballCol] = true;
}

void matrixEffect() {
  // Shift down occasionally
  if (effectStep % 3 == 0) {
    for (int row = 3; row &gt; 0; row--) {
      for (int col = 0; col &lt; 15; col++) {
        ledGrid[row][col] = ledGrid[row - 1][col];
      }
    }
    
    // Add random top pixels
    for (int col = 0; col &lt; 15; col++) {
      ledGrid[0][col] = (random(100) &lt; 15);
    }
  }
}

void rippleEffect() {
  clearGrid();
  int centerRow = 2;
  int centerCol = 7;
  int ripple1 = (effectStep * 2) % 25;
  int ripple2 = ((effectStep * 2) + 12) % 25;
  
  for (int row = 0; row &lt; 4; row++) {
    for (int col = 0; col &lt; 15; col++) {
      int dist = abs(row - centerRow) + abs(col - centerCol);
      if (dist == ripple1 || dist == ripple2) {
        ledGrid[row][col] = true;
      }
    }
  }
}

void waveEffect() {
  clearGrid();
  for (int col = 0; col &lt; 15; col++) {
    int height = 2 + sin((col + effectStep) * 0.5) * 1.5;
    for (int row = 0; row &lt; height &amp;&amp; row &lt; 4; row++) {
      ledGrid[3 - row][col] = true;
    }
  }
}

void rainEffect() {
  // Shift down
  for (int row = 3; row &gt; 0; row--) {
    for (int col = 0; col &lt; 15; col++) {
      ledGrid[row][col] = ledGrid[row - 1][col];
    }
  }
  
  // Add new drops
  for (int col = 0; col &lt; 15; col++) {
    ledGrid[0][col] = (random(100) &lt; 20);
  }
}

void spiralEffect() {
  clearGrid();
  int center = effectStep % 30;
  for (int i = 0; i &lt; 60; i++) {
    int pos = (center + i) % 60;
    int row = pos / 15;
    int col = pos % 15;
    if (i &lt; 15) ledGrid[row][col] = true;
  }
}

void pulseEffect() {
  clearGrid();
  int radius = (effectStep % 10) * 2;
  for (int row = 0; row &lt; 4; row++) {
    for (int col = 0; col &lt; 15; col++) {
      int dist = abs(row - 2) + abs(col - 7);
      if (dist == radius || dist == radius + 1) {
        ledGrid[row][col] = true;
      }
    }
  }
}

void clearGrid() {
  for (int row = 0; row &lt; 4; row++) {
    for (int col = 0; col &lt; 15; col++) {
      ledGrid[row][col] = false;
    }
  }
}</anyType>
        <anyType xsi:type="xsd:string" />
