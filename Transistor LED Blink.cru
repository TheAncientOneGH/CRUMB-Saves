        <anyType xsi:type="xsd:string">const int NPN = 4;
const int PNP = 5;

unsigned long lastTime = 0;

void setup() {
	Serial.begin(9600);
	pinMode(NPN, OUTPUT);
	pinMode(PNP, OUTPUT);
	digitalWrite(NPN, HIGH);
	digitalWrite(PNP, HIGH);
}

void loop() {
	unsigned long currentTime = millis();
	bool NPNVal = digitalRead(NPN);
	bool PNPVal = digitalRead(PNP);
	if (currentTime - lastTime &gt;= 1000) {
		if (NPNVal == LOW) {
			digitalWrite(NPN, HIGH);
		} else {
			digitalWrite(NPN, LOW);
		}
		if (PNPVal == LOW) {
			digitalWrite(PNP, HIGH);
		} else {
			digitalWrite(PNP, LOW);
		}
		lastTime = currentTime;
	}
}</anyType>
        <anyType xsi:type="xsd:string" />
      </data>
